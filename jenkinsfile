pipeline {
    agent any

    environment {
        DOCKER_HUB_REPO = 'img1'
       
        CONTAINER_NAME = 'cont1'
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/veeraprasadkoduri-cmd/veera.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('frontend/bikes-rental-system') {
                    sh "docker build -t $DOCKER_HUB_REPO ."
                }
            }
        }



        stage('Deploy Container') {
            steps {
                sh '''
                docker stop $CONTAINER_NAME || true
                docker rm $CONTAINER_NAME || true
                docker run -d -p 91:80 --name $CONTAINER_NAME $DOCKER_HUB_REPO
                '''
            }
        }
    }
}
